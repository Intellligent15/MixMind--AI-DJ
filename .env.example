# Database
DATABASE_URL=postgresql://aidj:aidj@localhost:5432/aidj

# Redis / Celery broker
REDIS_URL=redis://localhost:6379/0

# External APIs (stubbed in early phases)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GENIUS_ACCESS_TOKEN=
GEMINI_API_KEY=

# LLM provider selection: gemini | claude | openai
LLM_PROVIDER=gemini

# Storage backend: local | s3 (future)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./cache
CACHE_MAX_SIZE_GB=50

# Frontend → backend base URL used by the browser (Client Components).
# Server Components inside the frontend container use BACKEND_URL instead,
# which is set in docker-compose.yml.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Model selection
WHISPER_MODEL=large-v3
DEMUCS_MODEL=htdemucs_ft
DEMUCS_DEVICE=mps           # mps | cuda | cpu

# Logging
LOG_LEVEL=INFO
