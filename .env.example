# Database. docker-compose.yml overrides to postgres:5432 inside the
# backend/worker containers; this localhost default is for the native
# worker and pytest run on the host.
DATABASE_URL=postgresql+psycopg://aidj:aidj@localhost:5432/aidj

# Redis / Celery broker. Same dual-host story as above.
REDIS_URL=redis://localhost:6379/0

# External APIs (stubbed in early phases)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
GENIUS_ACCESS_TOKEN=
GEMINI_API_KEY=

# LLM provider selection: gemini | claude | openai
LLM_PROVIDER=gemini

# Storage backend: local | s3
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./cache
CACHE_MAX_SIZE_GB=50
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION_NAME=

# Modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# yt-dlp cookies file. On cloud hosts (the droplet) YouTube's anti-bot
# system blocks datacenter IPs unless yt-dlp passes a logged-in browser
# session. Drop a Netscape cookies.txt at the path below; leave empty
# for local-dev (residential IP works without auth). Use a Chrome
# extension like "Get cookies.txt LOCALLY" to export from youtube.com.
YT_DLP_COOKIES_FILE=

# Frontend → backend base URL used by the browser (Client Components).
# Server Components inside the frontend container use BACKEND_URL instead,
# which is set in docker-compose.yml.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Model selection
WHISPER_MODEL=large-v3
DEMUCS_MODEL=htdemucs_ft
DEMUCS_DEVICE=mps           # mps | cuda | cpu

# Logging
LOG_LEVEL=INFO
